{
    "displayName": "Home Bridge HTTP Plugins",
    "name": "homebridge-http-plugins",
    "version": "0.0.6",
    "description": "Homebridge dynamic platform plugin to control home devices (lights, air conditioner, fan, heater, elevator, IR, etc.) over local HTTP.",
    "license": "Apache-2.0",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/gusghrlrl101/homebridge-http-plugins.git"
    },
    "bugs": {
        "url": "https://github.com/gusghrlrl101/homebridge-http-plugins/issues"
    },
    "engines": {
        "node": "^22.10.0 || ^24.0.0",
        "homebridge": "^1.8.0 || ^2.0.0"
    },
    "main": "dist/index.js",
    "scripts": {
        "lint": "eslint . --max-warnings=0",
        "watch": "npm run build && npm link && nodemon",
        "build": "rimraf ./dist && tsc",
        "prepublishOnly": "npm run lint && npm run build"
    },
    "keywords": [
        "homebridge-plugin"
    ],
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "eslint": "^10.3.0",
        "homebridge": "^2.0.0",
        "nodemon": "^3.1.14",
        "rimraf": "^6.1.3",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2"
    },
    "dependencies": {
        "axios": "^1.16.1"
    }
}
